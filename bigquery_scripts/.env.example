# BigQuery Pipeline Configuration Template
# Copy this to .env and fill in your values

GCP_GCS_BUCKET: findata-bucket
GOOGLE_CLOUD_PROJECT: finance-zoomcamp
GOOGLE_APPLICATION_CREDENTIALS: /workspaces/finance-data-pipeline/.secrets/gcp/svc-account.json

# GCP Project Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_GCS_BUCKET=your-gcs-bucket-name

# Service Account Authentication
# Option 1: Service Account Key Path
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Option 2: Use Application Default Credentials (ADC)
# Leave GOOGLE_APPLICATION_CREDENTIALS empty and run:
# gcloud auth application-default login

# BigQuery Configuration
BIGQUERY_DATASET_ID=finance_data
BIGQUERY_LOCATION=US

# Data Configuration
CSV_BALANCE_SHEET=balance_sheet.csv
CSV_INCOME_STATEMENT=income_statement.csv
CSV_COMPANY_INFO=company_info.csv
CSV_CASH_FLOW=cash_flow_statement.csv

# Optional: Logging Configuration
LOG_LEVEL=INFO
